{% liquid
  assign default_locale = section.settings.default_locale | default: 'es'
  assign theme_logo = settings.logo
  assign logo_height = settings.logo_height | default: 36
  assign logo_height_mobile = settings.logo_height_mobile | default: 28
  assign logo_width = blank
  assign logo_width_mobile = blank

  if theme_logo != blank
    assign logo_width = logo_height | times: theme_logo.aspect_ratio | round
    assign logo_width_mobile = logo_height_mobile | times: theme_logo.aspect_ratio | round
  endif

  assign customer_form_id = 'PlenniaCustomerForm-' | append: section.id
%}

<section
  class="plennia-coming-soon"
  data-section-id="{{ section.id }}"
  data-default-locale="{{ default_locale }}"
>
  <div class="plennia-coming-soon__shell">
    <header class="plennia-coming-soon__header">
      <div class="plennia-coming-soon__header-empty"></div>

      <a
        class="plennia-coming-soon__brand"
        href="{{ routes.root_url }}"
        aria-label="{{ shop.name | escape }}"
      >
        {% if theme_logo != blank %}
          {{
            theme_logo
            | image_url: width: 720
            | image_tag:
              widths: '180, 240, 360, 540, 720',
              width: logo_width,
              height: logo_height,
              class: 'plennia-coming-soon__logo-image',
              sizes: '(max-width: 749px) ' | append: logo_width_mobile | append: 'px, ' | append: logo_width | append: 'px',
              alt: shop.name
          }}
        {% else %}
          <span class="plennia-coming-soon__logo-text">{{ section.settings.logo_text }}</span>
        {% endif %}
      </a>

      <div
        class="plennia-coming-soon__locale-switcher"
        role="group"
        aria-label="Language switcher"
      >
        <button
          type="button"
          class="plennia-coming-soon__locale-button"
          data-locale-button="es"
          aria-pressed="false"
        >
          ES
        </button>
        <button
          type="button"
          class="plennia-coming-soon__locale-button"
          data-locale-button="en"
          aria-pressed="false"
        >
          EN
        </button>
      </div>
    </header>

    <div class="plennia-coming-soon__divider" aria-hidden="true"></div>

    <main class="plennia-coming-soon__main">
      <div class="plennia-coming-soon__content">
        <div class="plennia-coming-soon__hero">
          <p
            class="plennia-coming-soon__eyebrow"
            data-i18n-key="eyebrow"
          >
            {{ section.settings.eyebrow_es }}
          </p>

          <h1
            class="plennia-coming-soon__heading"
            data-i18n-key="heading"
          >
            {{ section.settings.heading_es | newline_to_br }}
          </h1>

          <p
            class="plennia-coming-soon__tagline"
            data-i18n-key="tagline"
          >
            {{ section.settings.tagline_es }}
          </p>

          <p
            class="plennia-coming-soon__body"
            data-i18n-key="body"
          >
            {{ section.settings.body_es }}
          </p>
        </div>

        <div class="plennia-coming-soon__form-shell">
          <form
            class="plennia-coming-soon__ui-form"
            data-ui-form
            novalidate
          >
            <div class="plennia-coming-soon__fields">
              <div class="plennia-coming-soon__field-group">
                <label
                  class="plennia-coming-soon__label"
                  for="PlenniaName-{{ section.id }}"
                  data-i18n-key="fullNameLabel"
                >
                  {{ section.settings.full_name_label_es }}
                </label>
                <input
                  id="PlenniaName-{{ section.id }}"
                  class="plennia-coming-soon__input"
                  type="text"
                  name="full_name"
                  autocomplete="name"
                  placeholder="{{ section.settings.full_name_placeholder_es }}"
                  data-name-input
                  data-i18n-placeholder="fullNamePlaceholder"
                >
              </div>

              <div class="plennia-coming-soon__field-group">
                <span
                  class="plennia-coming-soon__label"
                  data-i18n-key="contactLabel"
                >
                  {{ section.settings.contact_label_es }}
                </span>

                <div
                  class="plennia-coming-soon__method-toggle"
                  role="tablist"
                  aria-label="Contact method"
                >
                  <button
                    type="button"
                    class="plennia-coming-soon__method-button"
                    data-method-button="email"
                    data-i18n-key="emailTab"
                    aria-pressed="false"
                  >
                    {{ section.settings.email_tab_es }}
                  </button>
                  <button
                    type="button"
                    class="plennia-coming-soon__method-button"
                    data-method-button="phone"
                    data-i18n-key="phoneTab"
                    aria-pressed="false"
                  >
                    {{ section.settings.phone_tab_es }}
                  </button>
                </div>
              </div>

              <div class="plennia-coming-soon__field-group">
                <input
                  id="PlenniaContact-{{ section.id }}"
                  class="plennia-coming-soon__input"
                  type="email"
                  name="contact_value"
                  autocomplete="email"
                  inputmode="email"
                  placeholder="{{ section.settings.email_placeholder_es }}"
                  data-contact-input
                >
                <p
                  class="plennia-coming-soon__field-error"
                  data-contact-error
                  hidden
                ></p>
              </div>

              <div class="plennia-coming-soon__field-group plennia-coming-soon__field-group--checkbox">
                <label class="plennia-coming-soon__checkbox">
                  <input
                    type="checkbox"
                    name="consent"
                    value="true"
                    data-consent-input
                  >
                  <span class="plennia-coming-soon__checkbox-box" aria-hidden="true"></span>
                  <span
                    class="plennia-coming-soon__checkbox-text"
                    data-consent-text
                  >
                    {{ section.settings.consent_email_es }}
                  </span>
                </label>
                <p
                  class="plennia-coming-soon__field-error"
                  data-consent-error
                  hidden
                ></p>
              </div>

              <button
                class="plennia-coming-soon__submit"
                type="submit"
                data-submit-button
              >
                <span data-i18n-key="submitLabel">{{ section.settings.submit_label_es }}</span>
              </button>

              <p
                class="plennia-coming-soon__field-error plennia-coming-soon__field-error--general"
                data-general-error
                hidden
              ></p>
            </div>

            <div
              class="plennia-coming-soon__success"
              data-success-state
              hidden
            >
              <p
                class="plennia-coming-soon__success-title"
                data-i18n-key="successTitle"
              >
                {{ section.settings.success_title_es }}
              </p>
              <p
                class="plennia-coming-soon__success-body"
                data-i18n-key="successBody"
              >
                {{ section.settings.success_body_es }}
              </p>
            </div>

            <div
              class="visually-hidden"
              aria-live="polite"
              data-status-live
            ></div>
          </form>
        </div>
      </div>
    </main>
  </div>

  {% comment %}
    Email waitlist uses Shopify's theme-native customer form so submissions write
    to Shopify's newsletter/customer flow and allow tags via contact[tags].
    Phone/SMS marketing writes aren't supported securely from theme code alone.
  {% endcomment %}
  {%- form 'customer', id: customer_form_id, class: 'plennia-coming-soon__transport-form' -%}
    <input
      type="hidden"
      name="contact[email]"
      value=""
      data-customer-email
    >
    <input
      type="hidden"
      name="contact[tags]"
      value=""
      data-customer-tags
    >
    <input
      type="hidden"
      name="contact[first_name]"
      value=""
      data-customer-first-name
    >
    <input
      type="hidden"
      name="contact[last_name]"
      value=""
      data-customer-last-name
    >
    <div
      hidden
      data-customer-transport-state="{{ section.id }}"
      data-state="{% if form.posted_successfully? %}success{% elsif form.errors %}error{% else %}idle{% endif %}"
    ></div>
  {%- endform -%}

  <script
    type="application/json"
    data-plennia-copy
  >
    {
      "es": {
        "metaTitle": {{ section.settings.meta_title_es | json }},
        "metaDescription": {{ section.settings.meta_description_es | json }},
        "eyebrow": {{ section.settings.eyebrow_es | json }},
        "heading": {{ section.settings.heading_es | json }},
        "tagline": {{ section.settings.tagline_es | json }},
        "body": {{ section.settings.body_es | json }},
        "fullNameLabel": {{ section.settings.full_name_label_es | json }},
        "fullNamePlaceholder": {{ section.settings.full_name_placeholder_es | json }},
        "contactLabel": {{ section.settings.contact_label_es | json }},
        "emailTab": {{ section.settings.email_tab_es | json }},
        "phoneTab": {{ section.settings.phone_tab_es | json }},
        "emailPlaceholder": {{ section.settings.email_placeholder_es | json }},
        "phonePlaceholder": {{ section.settings.phone_placeholder_es | json }},
        "consentEmail": {{ section.settings.consent_email_es | json }},
        "consentPhone": {{ section.settings.consent_phone_es | json }},
        "submitLabel": {{ section.settings.submit_label_es | json }},
        "successTitle": {{ section.settings.success_title_es | json }},
        "successBody": {{ section.settings.success_body_es | json }},
        "validation": {
          "email": {{ section.settings.invalid_email_es | json }},
          "phone": {{ section.settings.invalid_phone_es | json }},
          "consent": {{ section.settings.consent_required_es | json }},
          "submit": {{ section.settings.submit_error_es | json }},
          "phoneUnavailable": {{ section.settings.phone_unavailable_es | json }}
        }
      },
      "en": {
        "metaTitle": {{ section.settings.meta_title_en | json }},
        "metaDescription": {{ section.settings.meta_description_en | json }},
        "eyebrow": {{ section.settings.eyebrow_en | json }},
        "heading": {{ section.settings.heading_en | json }},
        "tagline": {{ section.settings.tagline_en | json }},
        "body": {{ section.settings.body_en | json }},
        "fullNameLabel": {{ section.settings.full_name_label_en | json }},
        "fullNamePlaceholder": {{ section.settings.full_name_placeholder_en | json }},
        "contactLabel": {{ section.settings.contact_label_en | json }},
        "emailTab": {{ section.settings.email_tab_en | json }},
        "phoneTab": {{ section.settings.phone_tab_en | json }},
        "emailPlaceholder": {{ section.settings.email_placeholder_en | json }},
        "phonePlaceholder": {{ section.settings.phone_placeholder_en | json }},
        "consentEmail": {{ section.settings.consent_email_en | json }},
        "consentPhone": {{ section.settings.consent_phone_en | json }},
        "submitLabel": {{ section.settings.submit_label_en | json }},
        "successTitle": {{ section.settings.success_title_en | json }},
        "successBody": {{ section.settings.success_body_en | json }},
        "validation": {
          "email": {{ section.settings.invalid_email_en | json }},
          "phone": {{ section.settings.invalid_phone_en | json }},
          "consent": {{ section.settings.consent_required_en | json }},
          "submit": {{ section.settings.submit_error_en | json }},
          "phoneUnavailable": {{ section.settings.phone_unavailable_en | json }}
        }
      }
    }
  </script>
</section>

{% stylesheet %}
  .plennia-coming-soon {
    --plennia-background: #f6f1e8;
    --plennia-surface: #fcfaf6;
    --plennia-text: #1f1a16;
    --plennia-muted: #746c63;
    --plennia-border: #d9d1c7;
    --plennia-border-strong: #26211d;
    --plennia-button-bg: #221d19;
    --plennia-button-hover: #15110e;
    --plennia-button-text: #f8f3eb;
    --plennia-success: #2f5c45;
    --plennia-error: #8a3e32;

    min-height: 100svh;
    background: var(--plennia-background);
    color: var(--plennia-text);
  }

  .plennia-coming-soon__shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: clamp(1.25rem, 2.5vw, 2rem) clamp(1.25rem, 3vw, 2.75rem);
  }

  .plennia-coming-soon__header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 1rem;
  }

  .plennia-coming-soon__header-empty {
    min-height: 1px;
  }

  .plennia-coming-soon__brand {
    justify-self: center;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .plennia-coming-soon__logo-image {
    display: block;
    width: auto;
    max-height: {{ logo_height }}px;
    height: auto;
  }

  .plennia-coming-soon__logo-text {
    font-family: var(--font-heading--family);
    font-size: clamp(1.1rem, 1rem + 0.7vw, 1.5rem);
    font-weight: var(--font-heading--weight);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__locale-switcher {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .plennia-coming-soon__locale-button {
    appearance: none;
    border: 1px solid transparent;
    background: transparent;
    color: var(--plennia-muted);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    padding: 0.35rem 0.5rem;
    text-transform: uppercase;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__locale-button[aria-pressed='true'] {
    color: var(--plennia-text);
    border-color: var(--plennia-border);
    background: rgb(255 255 255 / 0.45);
  }

  .plennia-coming-soon__divider {
    margin-top: 1.1rem;
    border-top: 1px solid var(--plennia-border);
  }

  .plennia-coming-soon__main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(2.5rem, 8vw, 7rem);
  }

  .plennia-coming-soon__content {
    width: min(100%, 64rem);
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    justify-items: center;
  }

  .plennia-coming-soon__hero {
    width: min(100%, 48rem);
    text-align: center;
  }

  .plennia-coming-soon__eyebrow {
    margin: 0 0 1.1rem;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(2.8rem, 7vw, 5.7rem);
    font-weight: var(--font-heading--weight);
    line-height: 0.95;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .plennia-coming-soon__tagline {
    margin: 1.2rem 0 0;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: clamp(1rem, 0.96rem + 0.18vw, 1.1rem);
    font-style: italic;
    line-height: 1.6;
  }

  .plennia-coming-soon__body {
    width: min(100%, 34rem);
    margin: 1rem auto 0;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: clamp(0.98rem, 0.93rem + 0.15vw, 1.05rem);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .plennia-coming-soon__form-shell {
    width: min(100%, 30rem);
  }

  .plennia-coming-soon__ui-form {
    width: 100%;
  }

  .plennia-coming-soon__fields {
    display: grid;
    gap: 1.1rem;
  }

  .plennia-coming-soon__field-group {
    display: grid;
    gap: 0.55rem;
  }

  .plennia-coming-soon__field-group--checkbox {
    gap: 0.45rem;
  }

  .plennia-coming-soon__label {
    color: var(--plennia-text);
    font-family: var(--font-body--family);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__method-toggle {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .plennia-coming-soon__method-button,
  .plennia-coming-soon__input,
  .plennia-coming-soon__submit {
    min-height: 3.4rem;
  }

  .plennia-coming-soon__method-button {
    appearance: none;
    border: 1px solid var(--plennia-border);
    background: transparent;
    color: var(--plennia-muted);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.9rem 1rem;
    text-transform: uppercase;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__method-button[aria-pressed='true'] {
    border-color: var(--plennia-border-strong);
    background: rgb(255 255 255 / 0.56);
    color: var(--plennia-text);
  }

  .plennia-coming-soon__input {
    width: 100%;
    border: 1px solid var(--plennia-border);
    border-radius: 0;
    background: transparent;
    color: var(--plennia-text);
    font-family: var(--font-body--family);
    font-size: 0.98rem;
    line-height: 1.4;
    padding: 0.85rem 1rem;
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__input::placeholder {
    color: rgb(116 108 99 / 0.8);
  }

  .plennia-coming-soon__input:focus-visible,
  .plennia-coming-soon__method-button:focus-visible,
  .plennia-coming-soon__locale-button:focus-visible,
  .plennia-coming-soon__submit:focus-visible {
    outline: 2px solid var(--plennia-border-strong);
    outline-offset: 2px;
  }

  .plennia-coming-soon__checkbox {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    cursor: pointer;
  }

  .plennia-coming-soon__checkbox input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .plennia-coming-soon__checkbox-box {
    width: 1rem;
    height: 1rem;
    margin-top: 0.2rem;
    border: 1px solid var(--plennia-border);
    background: transparent;
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__checkbox input:checked + .plennia-coming-soon__checkbox-box {
    border-color: var(--plennia-border-strong);
    background:
      linear-gradient(135deg, transparent 35%, var(--plennia-border-strong) 35%, var(--plennia-border-strong) 65%, transparent 65%),
      linear-gradient(45deg, transparent 45%, var(--plennia-border-strong) 45%, var(--plennia-border-strong) 55%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0.7rem 0.7rem;
  }

  .plennia-coming-soon__checkbox-text {
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.93rem;
    line-height: 1.6;
  }

  .plennia-coming-soon__submit {
    appearance: none;
    width: 100%;
    border: 1px solid var(--plennia-button-bg);
    border-radius: 0;
    background: var(--plennia-button-bg);
    color: var(--plennia-button-text);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    padding: 0.95rem 1.25rem;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 120ms ease,
      opacity 160ms ease;
  }

  .plennia-coming-soon__submit:hover {
    background: var(--plennia-button-hover);
    border-color: var(--plennia-button-hover);
  }

  .plennia-coming-soon__submit:active {
    transform: translateY(1px);
  }

  .plennia-coming-soon__submit[disabled] {
    cursor: wait;
    opacity: 0.7;
  }

  .plennia-coming-soon__field-error {
    margin: 0;
    color: var(--plennia-error);
    font-family: var(--font-body--family);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .plennia-coming-soon__field-error--general {
    text-align: center;
  }

  .plennia-coming-soon__success {
    padding-top: 0.45rem;
    text-align: center;
  }

  .plennia-coming-soon__success-title {
    margin: 0;
    color: var(--plennia-success);
    font-family: var(--font-heading--family);
    font-size: clamp(1.35rem, 1.15rem + 0.7vw, 1.8rem);
    font-weight: var(--font-heading--weight);
    line-height: 1.2;
  }

  .plennia-coming-soon__success-body {
    margin: 0.45rem 0 0;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .plennia-coming-soon__transport-form {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .plennia-coming-soon__shell {
      padding: 1rem 1rem 1.5rem;
    }

    .plennia-coming-soon__header {
      grid-template-columns: 1fr auto 1fr;
      align-items: start;
    }

    .plennia-coming-soon__logo-image {
      max-height: {{ logo_height_mobile }}px;
    }

    .plennia-coming-soon__main {
      padding-block: 2.75rem 3rem;
    }

    .plennia-coming-soon__content {
      gap: 2.25rem;
    }

    .plennia-coming-soon__heading {
      font-size: clamp(2.35rem, 12vw, 3.4rem);
    }

    .plennia-coming-soon__body {
      width: 100%;
    }

    .plennia-coming-soon__method-toggle {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .plennia-coming-soon__locale-button,
    .plennia-coming-soon__method-button,
    .plennia-coming-soon__input,
    .plennia-coming-soon__submit,
    .plennia-coming-soon__checkbox-box {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const script = document.currentScript;
    const section = script ? script.closest('.plennia-coming-soon') : null;
    if (!section) return;

    const copyElement = section.querySelector('[data-plennia-copy]');
    if (!copyElement) return;

    let copy;

    try {
      copy = JSON.parse(copyElement.textContent);
    } catch (error) {
      return;
    }

    const storageKey = 'plennia-coming-soon-locale';
    const defaultLocale = section.dataset.defaultLocale === 'en' ? 'en' : 'es';
    const uiForm = section.querySelector('[data-ui-form]');
    const nameInput = section.querySelector('[data-name-input]');
    const contactInput = section.querySelector('[data-contact-input]');
    const consentInput = section.querySelector('[data-consent-input]');
    const submitButton = section.querySelector('[data-submit-button]');
    const successState = section.querySelector('[data-success-state]');
    const statusLive = section.querySelector('[data-status-live]');
    const customerForm = section.querySelector(`#PlenniaCustomerForm-${section.dataset.sectionId}`);
    const customerEmail = section.querySelector('[data-customer-email]');
    const customerTags = section.querySelector('[data-customer-tags]');
    const customerFirstName = section.querySelector('[data-customer-first-name]');
    const customerLastName = section.querySelector('[data-customer-last-name]');
    const contactError = section.querySelector('[data-contact-error]');
    const consentError = section.querySelector('[data-consent-error]');
    const generalError = section.querySelector('[data-general-error]');
    const localeButtons = section.querySelectorAll('[data-locale-button]');
    const methodButtons = section.querySelectorAll('[data-method-button]');
    const textTargets = section.querySelectorAll('[data-i18n-key]');
    const placeholderTargets = section.querySelectorAll('[data-i18n-placeholder]');
    const consentText = section.querySelector('[data-consent-text]');

    if (!uiForm || !contactInput || !consentInput || !submitButton || !customerForm) return;

    const state = {
      locale: defaultLocale,
      method: 'email',
      submitted: false,
      pending: false,
    };

    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const phonePattern = /^\+?[0-9\s().-]{7,}$/;

    const setMetaDescription = (value) => {
      let meta = document.querySelector('meta[name="description"]');

      if (!meta) {
        meta = document.createElement('meta');
        meta.name = 'description';
        document.head.appendChild(meta);
      }

      meta.setAttribute('content', value || '');
    };

    const splitName = (value) => {
      const trimmed = value.trim().replace(/\s+/g, ' ');

      if (!trimmed) {
        return { firstName: '', lastName: '' };
      }

      const parts = trimmed.split(' ');

      if (parts.length === 1) {
        return { firstName: parts[0], lastName: '' };
      }

      return {
        firstName: parts.shift() || '',
        lastName: parts.join(' '),
      };
    };

    const currentCopy = () => copy[state.locale] || copy[defaultLocale];

    const clearErrors = () => {
      [contactError, consentError, generalError].forEach((element) => {
        if (!element) return;

        element.textContent = '';
        element.hidden = true;
      });
    };

    const setError = (element, message) => {
      if (!element) return;

      element.textContent = message;
      element.hidden = false;
    };

    const syncMethodCopy = () => {
      const localeCopy = currentCopy();

      contactInput.type = state.method === 'email' ? 'email' : 'tel';
      contactInput.inputMode = state.method === 'email' ? 'email' : 'tel';
      contactInput.autocomplete = state.method === 'email' ? 'email' : 'tel';
      contactInput.placeholder =
        state.method === 'email' ? localeCopy.emailPlaceholder : localeCopy.phonePlaceholder;
      contactInput.setAttribute(
        'aria-label',
        `${localeCopy.contactLabel} ${state.method === 'email' ? localeCopy.emailTab : localeCopy.phoneTab}`
      );

      if (consentText) {
        consentText.textContent =
          state.method === 'email' ? localeCopy.consentEmail : localeCopy.consentPhone;
      }

      methodButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.methodButton === state.method));
      });
    };

    const applyLocale = (locale) => {
      state.locale = locale === 'en' ? 'en' : 'es';
      const localeCopy = currentCopy();

      textTargets.forEach((element) => {
        const key = element.dataset.i18nKey;
        if (!key || localeCopy[key] == null) return;

        if (key === 'heading') {
          element.innerHTML = String(localeCopy[key]).replace(/\n/g, '<br>');
        } else {
          element.textContent = localeCopy[key];
        }
      });

      placeholderTargets.forEach((element) => {
        const key = element.dataset.i18nPlaceholder;
        if (!key || localeCopy[key] == null) return;

        element.setAttribute('placeholder', localeCopy[key]);
      });

      document.title = localeCopy.metaTitle || document.title;
      setMetaDescription(localeCopy.metaDescription || '');
      document.documentElement.lang = state.locale;

      localeButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.localeButton === state.locale));
      });

      syncMethodCopy();

      try {
        window.localStorage.setItem(storageKey, state.locale);
      } catch (error) {
        /* no-op */
      }
    };

    const setPending = (pending) => {
      state.pending = pending;
      submitButton.disabled = pending || state.submitted;
      uiForm.setAttribute('aria-busy', String(pending));
    };

    const markSuccess = () => {
      state.submitted = true;
      setPending(false);

      if (successState) {
        successState.hidden = false;
      }

      [nameInput, contactInput, consentInput].forEach((element) => {
        if (element) element.disabled = true;
      });

      methodButtons.forEach((button) => {
        button.disabled = true;
      });

      submitButton.disabled = true;

      if (statusLive) {
        statusLive.textContent = `${currentCopy().successTitle}. ${currentCopy().successBody}`;
      }
    };

    const submitCustomerForm = async () => {
      const response = await fetch(customerForm.action, {
        method: 'POST',
        body: new FormData(customerForm),
        credentials: 'same-origin',
        headers: {
          Accept: 'text/html',
        },
      });

      const responseText = await response.text();
      const parser = new DOMParser();
      const documentResponse = parser.parseFromString(responseText, 'text/html');
      const marker = documentResponse.querySelector(
        `[data-customer-transport-state="${section.dataset.sectionId}"]`
      );

      if (marker && marker.dataset.state === 'success') {
        return;
      }

      throw new Error('Customer form submission failed');
    };

    const validate = () => {
      clearErrors();
      const localeCopy = currentCopy();
      const contactValue = contactInput.value.trim();

      if (state.method === 'email') {
        if (!emailPattern.test(contactValue)) {
          setError(contactError, localeCopy.validation.email);
          return false;
        }
      } else {
        if (!phonePattern.test(contactValue)) {
          setError(contactError, localeCopy.validation.phone);
          return false;
        }
      }

      if (!consentInput.checked) {
        setError(consentError, localeCopy.validation.consent);
        return false;
      }

      return true;
    };

    const prepareCustomerForm = () => {
      const { firstName, lastName } = splitName(nameInput ? nameInput.value : '');

      customerEmail.value = contactInput.value.trim();
      customerTags.value = `coming-soon,waitlist,language_${state.locale}`;
      customerFirstName.value = firstName;
      customerLastName.value = lastName;
    };

    const handleSubmit = async (event) => {
      event.preventDefault();

      if (state.pending || state.submitted) return;
      if (!validate()) return;

      if (state.method === 'phone') {
        setError(contactError, currentCopy().validation.phoneUnavailable);
        return;
      }

      try {
        setPending(true);
        prepareCustomerForm();
        await submitCustomerForm();
        markSuccess();
      } catch (error) {
        setPending(false);
        setError(generalError, currentCopy().validation.submit);
      }
    };

    let initialLocale = defaultLocale;

    try {
      const storedLocale = window.localStorage.getItem(storageKey);
      if (storedLocale === 'es' || storedLocale === 'en') {
        initialLocale = storedLocale;
      }
    } catch (error) {
      /* no-op */
    }

    localeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const locale = button.dataset.localeButton;
        if (locale === 'es' || locale === 'en') {
          applyLocale(locale);
        }
      });
    });

    methodButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const method = button.dataset.methodButton;
        if (method !== 'email' && method !== 'phone') return;

        state.method = method;
        clearErrors();
        syncMethodCopy();
      });
    });

    [nameInput, contactInput].forEach((element) => {
      if (!element) return;

      element.addEventListener('input', () => {
        clearErrors();
      });
    });

    consentInput.addEventListener('change', () => {
      if (!consentError) return;

      if (consentInput.checked) {
        consentError.textContent = '';
        consentError.hidden = true;
      }
    });

    uiForm.addEventListener('submit', handleSubmit);
    applyLocale(initialLocale);
  })();
{% endjavascript %}

