{% liquid
  assign default_locale = section.settings.default_locale | default: 'es'
  assign theme_logo = settings.logo
  assign logo_height = settings.logo_height | default: 36
  assign logo_height_mobile = settings.logo_height_mobile | default: 28
  assign logo_height_display = logo_height | times: 2.19375 | round
  assign logo_height_mobile_display = logo_height_mobile | times: 2.19375 | round
  assign logo_style = ''

  if theme_logo != blank
    assign logo_width = logo_height_display | times: theme_logo.aspect_ratio | ceil
    assign logo_width_mobile = logo_height_mobile_display | times: theme_logo.aspect_ratio | ceil
    assign logo_style = '--plennia-logo-width: ' | append: logo_width | append: 'px; --plennia-logo-width-mobile: ' | append: logo_width_mobile | append: 'px; --plennia-logo-height: ' | append: logo_height_display | append: 'px; --plennia-logo-height-mobile: ' | append: logo_height_mobile_display | append: 'px;'
  endif

  if default_locale == 'en'
    assign eyebrow_text = section.settings.eyebrow_en
    assign heading_text = section.settings.heading_en
    assign tagline_text = section.settings.tagline_en
    assign body_text = section.settings.body_en
    assign full_name_label = section.settings.full_name_label_en
    assign full_name_placeholder = section.settings.full_name_placeholder_en
    assign contact_label = section.settings.contact_label_en
    assign email_tab_label = section.settings.email_tab_en
    assign phone_tab_label = section.settings.phone_tab_en
    assign email_placeholder = section.settings.email_placeholder_en
    assign consent_label = section.settings.consent_email_en
    assign submit_label = section.settings.submit_label_en
    assign success_title = section.settings.success_title_en
    assign success_body = section.settings.success_body_en
  else
    assign eyebrow_text = section.settings.eyebrow_es
    assign heading_text = section.settings.heading_es
    assign tagline_text = section.settings.tagline_es
    assign body_text = section.settings.body_es
    assign full_name_label = section.settings.full_name_label_es
    assign full_name_placeholder = section.settings.full_name_placeholder_es
    assign contact_label = section.settings.contact_label_es
    assign email_tab_label = section.settings.email_tab_es
    assign phone_tab_label = section.settings.phone_tab_es
    assign email_placeholder = section.settings.email_placeholder_es
    assign consent_label = section.settings.consent_email_es
    assign submit_label = section.settings.submit_label_es
    assign success_title = section.settings.success_title_es
    assign success_body = section.settings.success_body_es
  endif

  assign customer_form_id = 'PlenniaCustomerForm-' | append: section.id
%}

<section
  class="plennia-coming-soon"
  data-section-id="{{ section.id }}"
  data-default-locale="{{ default_locale }}"
>
  <div class="plennia-coming-soon__shell">
    <header class="plennia-coming-soon__header">
      <div class="plennia-coming-soon__header-empty"></div>

      <a
        class="plennia-coming-soon__brand"
        href="{{ routes.root_url }}"
        aria-label="{{ shop.name | escape }}"
      >
        {% if theme_logo != blank %}
          {% render 'image',
            image: theme_logo,
            class: 'plennia-coming-soon__logo-image',
            height: logo_height_display,
            alt_text_fallback: shop.name,
            text_fallback: shop.name,
            style: logo_style
          %}
        {% else %}
          <span class="plennia-coming-soon__logo-text">{{ section.settings.logo_text }}</span>
        {% endif %}
      </a>

      <div
        class="plennia-coming-soon__locale-switcher"
        role="group"
        aria-label="Language switcher"
      >
        <button
          type="button"
          class="plennia-coming-soon__locale-button"
          data-locale-button="es"
          aria-pressed="false"
          {% if default_locale == 'es' %}
            aria-current="true"
            hidden
            disabled
            aria-hidden="true"
            tabindex="-1"
          {% endif %}
        >
          <img
            class="plennia-coming-soon__locale-flag"
            src="{{ 'spain-flag.webp' | asset_url }}"
            alt=""
            loading="eager"
            width="24"
            height="16"
          >
          <span class="visually-hidden">ES</span>
        </button>
        <button
          type="button"
          class="plennia-coming-soon__locale-button"
          data-locale-button="en"
          aria-pressed="false"
          {% if default_locale == 'en' %}
            aria-current="true"
            hidden
            disabled
            aria-hidden="true"
            tabindex="-1"
          {% endif %}
        >
          <img
            class="plennia-coming-soon__locale-flag"
            src="{{ 'uk-flag.webp' | asset_url }}"
            alt=""
            loading="eager"
            width="24"
            height="16"
          >
          <span class="visually-hidden">EN</span>
        </button>
      </div>
    </header>

    <div class="plennia-coming-soon__divider" aria-hidden="true"></div>

    <main class="plennia-coming-soon__main">
      <div class="plennia-coming-soon__content">
        <div class="plennia-coming-soon__hero">
          <p
            class="plennia-coming-soon__eyebrow"
            data-i18n-key="eyebrow"
          >
            {{ eyebrow_text }}
          </p>

          <h1
            class="plennia-coming-soon__heading"
            data-i18n-key="heading"
          >
            {{ heading_text | newline_to_br }}
          </h1>

          <p
            class="plennia-coming-soon__tagline"
            data-i18n-key="tagline"
          >
            {{ tagline_text }}
          </p>

          <p
            class="plennia-coming-soon__body"
            data-i18n-key="body"
          >
            {{ body_text }}
          </p>
        </div>

        <div class="plennia-coming-soon__form-shell">
          <form
            class="plennia-coming-soon__ui-form"
            data-ui-form
            novalidate
          >
            <div class="plennia-coming-soon__fields">
              <div class="plennia-coming-soon__field-group">
                <label
                  class="plennia-coming-soon__label"
                  for="PlenniaName-{{ section.id }}"
                  data-i18n-key="fullNameLabel"
                >
                  {{ full_name_label }}
                </label>
                <input
                  id="PlenniaName-{{ section.id }}"
                  class="plennia-coming-soon__input"
                  type="text"
                  name="full_name"
                  autocomplete="name"
                  placeholder="{{ full_name_placeholder }}"
                  data-name-input
                  data-i18n-placeholder="fullNamePlaceholder"
                >
              </div>

              <div class="plennia-coming-soon__field-group">
                <span
                  class="plennia-coming-soon__label"
                  data-i18n-key="contactLabel"
                >
                  {{ contact_label }}
                </span>

                <div
                  class="plennia-coming-soon__method-toggle"
                  role="tablist"
                  aria-label="Contact method"
                >
                  <button
                    type="button"
                    class="plennia-coming-soon__method-button"
                    data-method-button="email"
                    data-i18n-key="emailTab"
                    aria-pressed="false"
                  >
                    {{ email_tab_label }}
                  </button>
                  <button
                    type="button"
                    class="plennia-coming-soon__method-button"
                    data-method-button="phone"
                    data-i18n-key="phoneTab"
                    aria-pressed="false"
                  >
                    {{ phone_tab_label }}
                  </button>
                </div>
              </div>

              <div class="plennia-coming-soon__field-group">
                <input
                  id="PlenniaContact-{{ section.id }}"
                  class="plennia-coming-soon__input"
                  type="email"
                  name="contact_value"
                  autocomplete="email"
                  inputmode="email"
                  placeholder="{{ email_placeholder }}"
                  data-contact-input
                >
                <p
                  class="plennia-coming-soon__field-error"
                  data-contact-error
                  hidden
                ></p>
              </div>

              <div class="plennia-coming-soon__field-group plennia-coming-soon__field-group--checkbox">
                <label class="plennia-coming-soon__checkbox">
                  <input
                    type="checkbox"
                    name="consent"
                    value="true"
                    data-consent-input
                  >
                  <span class="plennia-coming-soon__checkbox-box" aria-hidden="true"></span>
                  <span
                    class="plennia-coming-soon__checkbox-text"
                    data-consent-text
                  >
                    {{ consent_label }}
                  </span>
                </label>
                <p
                  class="plennia-coming-soon__field-error"
                  data-consent-error
                  hidden
                ></p>
              </div>

              <button
                class="plennia-coming-soon__submit"
                type="submit"
                data-submit-button
              >
                <span data-i18n-key="submitLabel">{{ submit_label }}</span>
              </button>

              <p
                class="plennia-coming-soon__field-error plennia-coming-soon__field-error--general"
                data-general-error
                hidden
              ></p>
            </div>

            <div
              class="plennia-coming-soon__success"
              data-success-state
              hidden
            >
              <p
                class="plennia-coming-soon__success-title"
                data-i18n-key="successTitle"
              >
                {{ success_title }}
              </p>
              <p
                class="plennia-coming-soon__success-body"
                data-i18n-key="successBody"
              >
                {{ success_body }}
              </p>
            </div>

            <div
              class="visually-hidden"
              aria-live="polite"
              data-status-live
            ></div>
          </form>
        </div>
      </div>
    </main>
  </div>

  {% comment %}
    Email waitlist uses Shopify's theme-native customer form so submissions write
    to Shopify's newsletter/customer flow and allow tags via contact[tags].
    Phone/SMS marketing writes aren't supported securely from theme code alone.
  {% endcomment %}
  {%- form 'customer', id: customer_form_id, class: 'plennia-coming-soon__transport-form' -%}
    <input
      type="hidden"
      name="contact[email]"
      value=""
      data-customer-email
    >
    <input
      type="hidden"
      name="contact[tags]"
      value=""
      data-customer-tags
    >
    <input
      type="hidden"
      name="contact[first_name]"
      value=""
      data-customer-first-name
    >
    <input
      type="hidden"
      name="contact[last_name]"
      value=""
      data-customer-last-name
    >
    <div
      hidden
      data-customer-transport-state="{{ section.id }}"
      data-state="{% if form.posted_successfully? %}success{% elsif form.errors %}error{% else %}idle{% endif %}"
    ></div>
  {%- endform -%}

  <script
    type="application/json"
    data-plennia-copy
  >
    {
      "es": {
        "metaTitle": {{ section.settings.meta_title_es | json }},
        "metaDescription": {{ section.settings.meta_description_es | json }},
        "eyebrow": {{ section.settings.eyebrow_es | json }},
        "heading": {{ section.settings.heading_es | json }},
        "tagline": {{ section.settings.tagline_es | json }},
        "body": {{ section.settings.body_es | json }},
        "fullNameLabel": {{ section.settings.full_name_label_es | json }},
        "fullNamePlaceholder": {{ section.settings.full_name_placeholder_es | json }},
        "contactLabel": {{ section.settings.contact_label_es | json }},
        "emailTab": {{ section.settings.email_tab_es | json }},
        "phoneTab": {{ section.settings.phone_tab_es | json }},
        "emailPlaceholder": {{ section.settings.email_placeholder_es | json }},
        "phonePlaceholder": {{ section.settings.phone_placeholder_es | json }},
        "consentEmail": {{ section.settings.consent_email_es | json }},
        "consentPhone": {{ section.settings.consent_phone_es | json }},
        "submitLabel": {{ section.settings.submit_label_es | json }},
        "successTitle": {{ section.settings.success_title_es | json }},
        "successBody": {{ section.settings.success_body_es | json }},
        "validation": {
          "email": {{ section.settings.invalid_email_es | json }},
          "phone": {{ section.settings.invalid_phone_es | json }},
          "consent": {{ section.settings.consent_required_es | json }},
          "submit": {{ section.settings.submit_error_es | json }},
          "phoneUnavailable": {{ section.settings.phone_unavailable_es | json }}
        }
      },
      "en": {
        "metaTitle": {{ section.settings.meta_title_en | json }},
        "metaDescription": {{ section.settings.meta_description_en | json }},
        "eyebrow": {{ section.settings.eyebrow_en | json }},
        "heading": {{ section.settings.heading_en | json }},
        "tagline": {{ section.settings.tagline_en | json }},
        "body": {{ section.settings.body_en | json }},
        "fullNameLabel": {{ section.settings.full_name_label_en | json }},
        "fullNamePlaceholder": {{ section.settings.full_name_placeholder_en | json }},
        "contactLabel": {{ section.settings.contact_label_en | json }},
        "emailTab": {{ section.settings.email_tab_en | json }},
        "phoneTab": {{ section.settings.phone_tab_en | json }},
        "emailPlaceholder": {{ section.settings.email_placeholder_en | json }},
        "phonePlaceholder": {{ section.settings.phone_placeholder_en | json }},
        "consentEmail": {{ section.settings.consent_email_en | json }},
        "consentPhone": {{ section.settings.consent_phone_en | json }},
        "submitLabel": {{ section.settings.submit_label_en | json }},
        "successTitle": {{ section.settings.success_title_en | json }},
        "successBody": {{ section.settings.success_body_en | json }},
        "validation": {
          "email": {{ section.settings.invalid_email_en | json }},
          "phone": {{ section.settings.invalid_phone_en | json }},
          "consent": {{ section.settings.consent_required_en | json }},
          "submit": {{ section.settings.submit_error_en | json }},
          "phoneUnavailable": {{ section.settings.phone_unavailable_en | json }}
        }
      }
    }
  </script>
</section>

{% stylesheet %}
  .plennia-coming-soon {
    --plennia-background: #f9f8f3;
    --plennia-surface: #fcfaf6;
    --plennia-text: #2b241f;
    --plennia-text-soft: #3a312b;
    --plennia-muted: #7b7268;
    --plennia-border: #ddd5cb;
    --plennia-border-strong: #b9aea2;
    --plennia-border-focus: #a59688;
    --plennia-control-surface: #f1ebe2;
    --plennia-control-active: #e3dbcf;
    --plennia-control-hover: #f6f1e8;
    --plennia-button-bg: #2c241e;
    --plennia-button-hover: #241d18;
    --plennia-button-text: #f8f3eb;
    --plennia-success: #2f5c45;
    --plennia-error: #8a3e32;

    min-height: 100svh;
    background: var(--plennia-background);
    color: var(--plennia-text);
  }

  .plennia-coming-soon__shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: clamp(1.35rem, 2.8vw, 2.35rem) clamp(1.1rem, 4vw, 3.5rem) clamp(1.65rem, 3vw, 2.5rem);
  }

  .plennia-coming-soon__header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.85rem;
  }

  .plennia-coming-soon__header-empty {
    min-height: 1px;
  }

  .plennia-coming-soon__brand {
    justify-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    text-decoration: none;
    color: inherit;
    padding-block: clamp(0.15rem, 0.5vw, 0.45rem);
  }

  .plennia-coming-soon__logo-image {
    display: block;
    width: var(--plennia-logo-width-mobile, auto);
    max-width: min(18rem, 42vw);
    height: var(--plennia-logo-height-mobile, auto);
    object-fit: contain;
  }

  @media screen and (min-width: 750px) {
    .plennia-coming-soon__logo-image {
      width: var(--plennia-logo-width, auto);
      height: var(--plennia-logo-height, auto);
    }
  }

  .plennia-coming-soon__logo-text {
    font-family: var(--font-heading--family);
    font-size: clamp(1.1rem, 1rem + 0.7vw, 1.5rem);
    font-weight: var(--font-heading--weight);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__locale-switcher {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .plennia-coming-soon__locale-button {
    appearance: none;
    border: 0;
    border-bottom: 1px solid transparent;
    background: transparent;
    color: var(--plennia-muted);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    line-height: 1;
    padding: 0.2rem 0.1rem 0.35rem;
    text-transform: uppercase;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__locale-flag {
    display: block;
    width: 1.5rem;
    height: 1rem;
    object-fit: cover;
    border-radius: 2px;
  }

  .plennia-coming-soon__locale-button[aria-pressed='true'] {
    color: var(--plennia-text);
    border-color: var(--plennia-border-strong);
    background: transparent;
  }

  .plennia-coming-soon__divider {
    margin-top: 1.35rem;
    border-top: 1px solid var(--plennia-border);
  }

  .plennia-coming-soon__main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(3rem, 9vw, 8.5rem);
  }

  .plennia-coming-soon__content {
    width: min(100%, 58rem);
    display: grid;
    gap: clamp(2.75rem, 5.5vw, 5.25rem);
    justify-items: center;
  }

  .plennia-coming-soon__hero {
    width: min(100%, 43rem);
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .plennia-coming-soon__eyebrow {
    margin: 0 0 1.3rem;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__heading {
    margin: 0;
    width: min(100%, 11ch);
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 7.4vw, 6.1rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .plennia-coming-soon__tagline {
    width: min(100%, 27rem);
    margin: 1.55rem 0 0;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: clamp(1rem, 0.96rem + 0.14vw, 1.08rem);
    font-style: italic;
    line-height: 1.7;
  }

  .plennia-coming-soon__body {
    width: min(100%, 31rem);
    margin: 1.35rem auto 0;
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: clamp(0.97rem, 0.93rem + 0.12vw, 1.03rem);
    line-height: 1.82;
    text-wrap: pretty;
  }

  .plennia-coming-soon__form-shell {
    width: min(100%, 27.5rem);
  }

  .plennia-coming-soon__ui-form {
    width: 100%;
  }

  .plennia-coming-soon__fields {
    display: grid;
    gap: 1.2rem;
  }

  .plennia-coming-soon__field-group {
    display: grid;
    gap: 0.65rem;
  }

  .plennia-coming-soon__field-group--checkbox {
    gap: 0.5rem;
  }

  .plennia-coming-soon__label {
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .plennia-coming-soon__method-toggle {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    padding: 0.18rem;
    border: 1px solid var(--plennia-border);
    border-radius: 8px;
    background: var(--plennia-control-surface);
    box-shadow: none;
    overflow: hidden;
  }

  .plennia-coming-soon__method-button,
  .plennia-coming-soon__input,
  .plennia-coming-soon__submit {
    min-height: 3.55rem;
  }

  .plennia-coming-soon__method-button {
    appearance: none;
    position: relative;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--plennia-muted);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.73rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    padding: 0.95rem 1rem;
    text-transform: uppercase;
    transition:
      border-color 150ms ease-in-out,
      color 150ms ease-in-out,
      background-color 150ms ease-in-out,
      transform 150ms ease-in-out;
  }

  .plennia-coming-soon__method-button[aria-pressed='true'] {
    border-color: var(--plennia-border-strong);
    background: var(--plennia-control-active);
    box-shadow: inset 0 0 0 1px rgb(185 174 162 / 0.32);
    color: var(--plennia-text);
    z-index: 1;
  }

  .plennia-coming-soon__method-button[aria-pressed='false'] {
    background: transparent;
    color: var(--plennia-muted);
  }

  .plennia-coming-soon__method-button[aria-pressed='false']:hover {
    background: var(--plennia-control-hover);
  }

  .plennia-coming-soon__method-button[aria-pressed='true']:hover {
    background: var(--plennia-control-active);
  }

  .plennia-coming-soon__method-button:active {
    transform: scale(0.98);
  }

  .plennia-coming-soon__input {
    width: 100%;
    border: 1px solid var(--plennia-border);
    border-radius: 8px;
    background: rgb(252 250 246 / 0.52);
    color: var(--plennia-text-soft);
    font-family: var(--font-body--family);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.45;
    padding: 0.95rem 1rem;
    transition:
      border-color 150ms ease-in-out,
      background-color 150ms ease-in-out;
  }

  .plennia-coming-soon__input:focus-visible {
    border-color: var(--plennia-border-focus);
    background: var(--plennia-surface);
  }

  .plennia-coming-soon__input::placeholder {
    color: rgb(123 114 104 / 0.82);
  }

  .plennia-coming-soon__method-button:focus-visible,
  .plennia-coming-soon__locale-button:focus-visible,
  .plennia-coming-soon__submit:focus-visible {
    outline: 1px solid var(--plennia-border-focus);
    outline-offset: 1px;
  }

  .plennia-coming-soon__input:focus-visible {
    outline: none;
  }

  .plennia-coming-soon__checkbox {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: start;
    cursor: pointer;
  }

  .plennia-coming-soon__checkbox input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .plennia-coming-soon__checkbox-box {
    width: 1.05rem;
    height: 1.05rem;
    margin-top: 0.25rem;
    border: 1px solid var(--plennia-border);
    background: transparent;
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .plennia-coming-soon__checkbox input:checked + .plennia-coming-soon__checkbox-box {
    border-color: var(--plennia-border-strong);
    background:
      linear-gradient(135deg, transparent 35%, var(--plennia-border-strong) 35%, var(--plennia-border-strong) 65%, transparent 65%),
      linear-gradient(45deg, transparent 45%, var(--plennia-border-strong) 45%, var(--plennia-border-strong) 55%, transparent 55%);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 0.7rem 0.7rem;
  }

  .plennia-coming-soon__checkbox-text {
    color: var(--plennia-muted);
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.65;
  }

  .plennia-coming-soon__submit {
    appearance: none;
    width: 100%;
    border: 1px solid var(--plennia-button-bg);
    border-radius: 8px;
    background: var(--plennia-button-bg);
    color: var(--plennia-button-text);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    padding: 1rem 1.25rem;
    text-transform: uppercase;
    transition:
      background-color 150ms ease-in-out,
      border-color 150ms ease-in-out,
      transform 150ms ease-in-out,
      opacity 150ms ease-in-out;
  }

  .plennia-coming-soon__submit:hover {
    background: var(--plennia-button-hover);
    border-color: var(--plennia-button-hover);
  }

  .plennia-coming-soon__submit:active {
    transform: translateY(1px);
  }

  .plennia-coming-soon__submit[disabled] {
    cursor: wait;
    opacity: 0.7;
  }

  .plennia-coming-soon__field-error {
    margin: 0;
    color: var(--plennia-error);
    font-family: var(--font-body--family);
    font-size: 0.82rem;
